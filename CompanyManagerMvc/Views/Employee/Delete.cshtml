@model CompanyManager.Core.Models.Employee

<div class="container mt-4">

    <div class="card shadow border-0">

        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">
                <i class="bi bi-exclamation-triangle"></i>
                Delete Employee
            </h3>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                Are you sure you want to delete this employee?
            </div>

            <dl class="row">

                <dt class="col-sm-3">
                    Id
                </dt>

                <dd class="col-sm-9">
                    @Model.Id
                </dd>

                <dt class="col-sm-3">
                    Name
                </dt>

                <dd class="col-sm-9">
                    @Model.Name
                </dd>

                <dt class="col-sm-3">
                    Salary
                </dt>

                <dd class="col-sm-9">
                    @Model.Salary
                </dd>

                <dt class="col-sm-3">
                    Department
                </dt>

                <dd class="col-sm-9">
                    @Model.Department?.Name
                </dd>

            </dl>

            <form asp-controller="Employee"
                  asp-action="DeleteConfirmed"
                  method="post">

                <input type="hidden"
                       name="id"
                       value="@Model.Id" />

                <button type="submit"
                        class="btn btn-danger">
                    <i class="bi bi-trash"></i>
                    Delete
                </button>

                <a asp-controller="Employee"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>
