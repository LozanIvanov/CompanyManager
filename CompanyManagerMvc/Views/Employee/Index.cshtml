@model List<CompanyManager.Core.Models.Employee>
<div class="container">
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Employees</h1>

    <a asp-controller="Employee"
       asp-action="Create"
       class="btn btn-success">
            <i class="bi bi-plus-circle"></i>
        Create Employee
    </a>
</div>
    <div class="row mb-4">

        <div class="col-md-4">

            <form asp-controller="Employee"
                  asp-action="Index"
                  method="get">

                <div class="input-group">

                    <input type="text"
                           name="searchText"
                           value="@ViewBag.SearchText"
                           class="form-control"
                           placeholder="Search employee by name..." />

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-search"></i>
                        Search

                    </button>

               
                <a asp-controller="Employee"
                   asp-action="Index"
                   class="btn btn-secondary ms-2">
                    <i class="bi bi-x-circle"></i>
                    Clear
                </a>
                </div>

            </form>

        </div>

    </div>

<table class="table table-striped table-bordered text-center align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Salary</th>
            <th>Department</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.Salary</td>
                <td>@employee.Department?.Name</td>

                <td>
                    <a asp-controller="Employee"
                       asp-action="Edit"
                       asp-route-id="@employee.Id"
                       class="btn btn-primary"
                       style="width:100px">
                            <i class="bi bi-pencil-square"></i>
                        Edit
                    </a>
                </td>

                <td>
                    <form asp-controller="Employee"
                          asp-action="Delete"
                          method="post">

                        <input type="hidden"
                               name="id"
                               value="@employee.Id" />

                        <button type="submit" 
                            class="btn btn-danger" 
                            style="width:100px">
                                <i class="bi bi-trash"></i>
                            Delete</button>

                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

</div>
