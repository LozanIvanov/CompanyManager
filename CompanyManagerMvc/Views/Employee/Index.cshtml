@model CompanyManagerMvc.ViewModels.EmployeeIndexViewModel
<div class="container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close">
            </button>

        </div>
    }
    <h1>Employees</h1>
    <div class="d-flex align-items-center mb-3">
       
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Employee"
               asp-action="Create"
               class="btn btn-success me-2">
                <i class="bi bi-plus-circle"></i>
                Create Employee
            </a>
            <a asp-controller="Employee"
               asp-action="ExportToExcel"
               class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel"></i>
                Export to Excel
            </a>
        }
    </div>
    <div class="row mb-4">

        <div class="col-md-4">

            <form asp-controller="Employee"
                  asp-action="Index"
                  method="get"
                  class="mb-4">

                <div class="input-group">

                    <input type="text"
                           name="searchText"
                           value="@Model.SearchText"
                           class="form-control"
                           placeholder="Search employee by name..." />

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-search"></i>
                        Search

                    </button>


                    <a asp-controller="Employee"
                       asp-action="Index"
                       class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle"></i>
                        Clear
                    </a>
                </div>
                <div class="mt-3">

                    <select name="departmentId"
                            class="form-select">

                        <option value="">All Departments</option>

                        @foreach (var department in Model.Departments)
                        {
                            if (department.Id == Model.SelectedDepartmentId)
                            {
                                <option value="@department.Id" selected>
                                    @department.Name
                                </option>
                            }
                            else
                            {
                                <option value="@department.Id">
                                    @department.Name
                                </option>
                            }
                        }

                    </select>

                </div>
            </form>

        </div>


    </div>
    @if (!Model.Employees.Any())
    {
        <div class="alert alert-warning">
            No employees found.
        </div>
    }
    else
    {

        <table class="table table-striped table-bordered text-center align-middle">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@Model.NameSort"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-pageSize="@Model.PageSize">

                            Name
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@Model.SalarySort"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-pageSize="@Model.PageSize">
                            Salary
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@Model.DepartmentSort"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-pageSize="@Model.PageSize">
                            Department
                        </a>
                    </th>
                    <th>Details</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>Edit</th>
                        <th>Delete</th>
                    }
                </tr>
            </thead>

            <tbody>
                @foreach (var employee in Model.Employees)
                {
                    <tr>
                        <td>@employee.Id</td>
                        <td>@employee.Name</td>
                        <td>@employee.Salary</td>
                        <td>@employee.Department?.Name</td>
                        <td>
                            <a asp-controller="Employee"
                               asp-action="Details"
                               asp-route-id="@employee.Id"
                               class="btn btn-info"
                               style="width:100px">
                                <i class="bi bi-info-circle"></i>
                                Details
                            </a>
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                <a asp-controller="Employee"
                                   asp-action="Edit"
                                   asp-route-id="@employee.Id"
                                   class="btn btn-primary"
                                   style="width:100px">
                                    <i class="bi bi-pencil-square"></i>
                                    Edit
                                </a>
                            </td>

                            <td>
                                <a asp-controller="Employee"
                                   asp-action="Delete"
                                   asp-route-id="@employee.Id"
                                   class="btn btn-danger"
                                   style="width:100px">
                                    <i class="bi bi-trash"></i>
                                    Delete
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>

        <nav class="mt-3">
            <ul class="pagination justify-content-center">

                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-sortOrder="@Model.SortOrder">
                            Previous
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-sortOrder="@Model.SortOrder">
                            @i
                        </a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-sortOrder="@Model.SortOrder">
                            Next
                        </a>
                    </li>
                }

            </ul>
        </nav>


    }
</div>
