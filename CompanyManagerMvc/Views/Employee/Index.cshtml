@model CompanyManagerMvc.ViewModels.EmployeeIndexViewModel
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Employees</h1>

        <a asp-controller="Employee"
           asp-action="Create"
           class="btn btn-success">
            <i class="bi bi-plus-circle"></i>
            Create Employee
        </a>
    </div>
    <div class="row mb-4">

        <div class="col-md-4">

            <form asp-controller="Employee"
                  asp-action="Index"
                  method="get"
                  class="mb-4">

                <div class="input-group">

                    <input type="text"
                           name="searchText"
                           value="@Model.SearchText"
                           class="form-control"
                           placeholder="Search employee by name..." />

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-search"></i>
                        Search

                    </button>


                    <a asp-controller="Employee"
                       asp-action="Index"
                       class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle"></i>
                        Clear
                    </a>
                </div>
                <div class="mt-3">

                    <select name="departmentId"
                            class="form-select">

                        <option value="">All Departments</option>

                        @foreach (var department in Model.Departments)
                        {
                            if (department.Id == Model.SelectedDepartmentId)
                            {
                                <option value="@department.Id" selected>
                                    @department.Name
                                </option>
                            }
                            else
                            {
                                <option value="@department.Id">
                                    @department.Name
                                </option>
                            }
                        }

                    </select>

                </div>
            </form>

        </div>
       

    </div>
    @if (!Model.Employees.Any())
    {
        <div class="alert alert-warning">
            No employees found.
        </div>
    }
    else{

    <table class="table table-striped table-bordered text-center align-middle">
        <thead>
            <tr>
                <th>Id</th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@Model.NameSort"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId">
                            Name
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@Model.SalarySort"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId">
                            Salary
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index"
                           asp-route-sortOrder="@Model.DepartmentSort"
                           asp-route-searchText="@Model.SearchText"
                           asp-route-departmentId="@Model.SelectedDepartmentId">
                            Department
                        </a>
                    </th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var employee in Model.Employees)
            {
                <tr>
                    <td>@employee.Id</td>
                    <td>@employee.Name</td>
                    <td>@employee.Salary</td>
                    <td>@employee.Department?.Name</td>

                    <td>
                        <a asp-controller="Employee"
                           asp-action="Edit"
                           asp-route-id="@employee.Id"
                           class="btn btn-primary"
                           style="width:100px">
                            <i class="bi bi-pencil-square"></i>
                            Edit
                        </a>
                    </td>

                    <td>
                        <form asp-controller="Employee"
                              asp-action="Delete"
                              method="post">

                            <input type="hidden"
                                   name="id"
                                   value="@employee.Id" />

                            <button type="submit"
                                    class="btn btn-danger"
                                    style="width:100px">
                                <i class="bi bi-trash"></i>
                                Delete
                            </button>

                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    }
</div>
