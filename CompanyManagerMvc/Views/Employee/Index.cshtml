@model List<CompanyManager.Core.Models.Employee>
<div class="container">
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Employees</h1>

    <a asp-controller="Employee"
       asp-action="Create"
       class="btn btn-success">
        Create Employee
    </a>
</div>

<table class="table table-striped table-bordered text-center align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Salary</th>
            <th>Department</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.Salary</td>
                <td>@employee.Department?.Name</td>

                <td>
                    <a asp-controller="Employee"
                       asp-action="Edit"
                       asp-route-id="@employee.Id"
                       class="btn btn-primary"
                       style="width:100px">
                        Edit
                    </a>
                </td>

                <td>
                    <form asp-controller="Employee"
                          asp-action="Delete"
                          method="post">

                        <input type="hidden"
                               name="id"
                               value="@employee.Id" />

                        <button type="submit" class="btn btn-danger" style="width:100px">Delete</button>

                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

</div>
