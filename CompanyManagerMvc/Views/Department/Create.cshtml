@model CompanyManager.Core.Models.Department
<div class="container">
<h1>Create Department</h1>
<form asp-controller="Department"
asp-action="Create"
method="post">
    <div class="mb-3">
        <label class="form-label">Name</label>

            <input asp-for="Name"
               class="form-control" />

        <span asp-validation-for="Name"
              class="text-danger"></span>
    </div>
        <button type="submit"
                class="btn btn-warning">
            <i class="bi bi-pencil-square"></i>
            Create Department
        </button>
</form>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}