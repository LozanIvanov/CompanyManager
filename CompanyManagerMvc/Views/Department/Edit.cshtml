@model CompanyManager.Core.Models.Department

<h1>Edit Department</h1>

<form asp-controller="Department"
      asp-action="Edit"
      method="post"
>
   <input type="hidden" name="Id"value="@Model.Id"/>
   <label>Name</label>
   <input name="Name" value="@Model.Name"/>
   <button type="submit" >Update</button>

</form>
