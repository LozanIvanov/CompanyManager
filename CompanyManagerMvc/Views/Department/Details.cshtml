@model CompanyManager.Core.Models.Department

<div class="container mt-4">

    <h2>Department Details</h2>

    <hr />

    <dl class="row">

        <dt class="col-sm-3">
            Id
        </dt>

        <dd class="col-sm-9">
            @Model.Id
        </dd>

        <dt class="col-sm-3">
            Name
        </dt>

        <dd class="col-sm-9">
            @Model.Name
        </dd>

        <dt class="col-sm-3">
            Total Employees
        </dt>

        <dd class="col-sm-9">
            @Model.Employees.Count
        </dd>

    </dl>

    <h4 class="mt-4">Employees</h4>

    <table class="table table-striped table-bordered">

        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Salary</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var employee in Model.Employees)
            {
                <tr>
                    <td>@employee.Id</td>
                    <td>@employee.Name</td>
                    <td>@employee.Salary</td>
                </tr>
            }

        </tbody>

    </table>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-primary">
        Edit
    </a>

</div>