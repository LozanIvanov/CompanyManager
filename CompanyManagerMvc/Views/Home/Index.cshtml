@model CompanyManagerMvc.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Company Manager";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="display-4">
            <i class="bi bi-building"></i>
            Company Manager
        </h1>

        <p class="lead">
            Manage employees and departments in one place.
        </p>

    </div>

    <div class="row justify-content-center g-4">

        @foreach (var card in Model.Cards)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">

                <div class="card dashboard-card shadow-lg border-0 h-100 text-center">

                    <div class="card-body p-4">

                        <h3 class="card-title mb-4">

                            <i class="@card.Icon"></i>

                            @card.Title

                        </h3>

                        <h1 class="display-3 fw-bold mb-4">
                            @card.Count
                        </h1>

                        <a asp-controller="@card.Controller"
                           asp-action="Index"
                           class="btn @card.ButtonClass btn-lg w-100">

                            @card.ButtonText

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>