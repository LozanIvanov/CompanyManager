@model CompanyManagerMvc.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Company Manager";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="display-4">
            <i class="bi bi-building"></i>
            Company Manager
        </h1>

        <p class="lead">
            Manage employees and departments in one place.
        </p>

    </div>

    <div class="row justify-content-center g-4">

        @foreach (var card in Model.Cards)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">

                <div class="card dashboard-card shadow-lg border-0 h-100 text-center">

                    <div class="card-body p-4">

                        <h3 class="card-title mb-4">

                            <i class="@card.Icon"></i>

                            @card.Title

                        </h3>

                        <h1 class="display-3 fw-bold mb-4">
                            @card.Count
                        </h1>

                        <a asp-controller="@card.Controller"
                           asp-action="Index"
                           class="btn @card.ButtonClass btn-lg w-100">

                            @card.ButtonText

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>
    <div class="row justify-content-center mt-5 g-4">

        <div class="col-md-3">
            <div class="card shadow border-0 text-center h-100">
                <div class="card-body">
                    <h5>Average Salary</h5>
                    <h3>@Model.AverageSalary.ToString("F2")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center h-100">
                <div class="card-body">
                    <h5>Highest Salary</h5>
                    <h3>@Model.HighestSalary.ToString("F2")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center h-100">
                <div class="card-body">
                    <h5>Lowest Salary</h5>
                    <h3>@Model.LowestSalary.ToString("F2")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center h-100">
                <div class="card-body">
                    <h5>Total Salary</h5>
                    <h3>@Model.TotalSalary.ToString("F2")</h3>
                </div>
            </div>
        </div>

    </div>
    <div class="row justify-content-center mt-5">
        <div class="col-lg-8">

            <div class="card shadow border-0">

                <div class="card-body p-4">

                    <h4 class="text-center mb-4">
                        <i class="bi bi-bar-chart"></i>
                        Employees by Department
                    </h4>

                    <div style="height: 350px;">
                        <canvas id="departmentChart"></canvas>
                    </div>

                </div>

            </div>

        </div>
    </div>

</div>
@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const departmentLabels = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(
                            Model.DepartmentStatistics
                                    .Select(x => x.DepartmentName)));

    const employeeCounts = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                        Model.DepartmentStatistics
                                .Select(x => x.EmployeeCount)));

    const chartElement =
        document.getElementById('departmentChart');

        new Chart(chartElement, {
            type: 'bar',

            data: {
                labels: departmentLabels,

                datasets: [{
                    label: 'Employees',
                    data: employeeCounts,
                    borderWidth: 1
                }]
            },

            options: {
                responsive: true,
                maintainAspectRatio: false,

                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                }
            }
        });
    </script>
}